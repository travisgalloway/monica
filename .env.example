# Secrets for the cloud corpus + distillation pipeline. Copy to `.env` and fill in real
# values — `.env` is gitignored and MUST NOT be committed (docs/infrastructure.md: secrets
# live in the host env/secret store, never in the repo).
#
# Load into the current shell before running pipeline stages:
#     set -a; . ./.env; set +a

# --- Hugging Face -----------------------------------------------------------------------
# Read token (https://huggingface.co/settings/tokens). Used by huggingface_hub / transformers
# to download the Qwen3 tokenizer and the teacher (Qwen/Qwen3-4B-Thinking-2507); see
# src/model/mlx_teacher.py (snapshot_download). Required for the corpus build (tokenizer).
HF_TOKEN=<your-hf-read-token>

# --- Cloudflare R2 (S3-compatible object store) -----------------------------------------
# R2 API token, addressed through the S3 scheme by fsspec/s3fs (src/data/corpus.py uses
# fsspec.core.url_to_fs). Used when artifact paths switch from file:// to s3:// (#80).
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2 S3 endpoint for your account (Cloudflare dashboard → R2 → "S3 API"):
AWS_ENDPOINT_URL_S3=https://<account-id>.r2.cloudflarestorage.com
# Bucket holding the poc-distill/ · shared/ · reserve-pretrain/ · ckpt/ prefixes (src/data/storage.py).
R2_BUCKET=monica-training
# R2
R2_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- RunPod -----------------------------------------------------------------------------
# API key for provisioning the CPU/GPU pods that run the heavy stages: teacher top-k logit
# precompute (#94) and the cloud distill smoke run (#81). Not needed for local stages.
RUNPOD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
